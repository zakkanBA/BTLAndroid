rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && userDoc().data.isAdmin == true;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function notBanned() {
      return signedIn() && userDoc().data.isBanned != true;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && isOwner(userId);
      allow update: if signedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && notBanned()
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && (isOwner(resource.data.userId) || isAdmin())
        && (isAdmin() || notBanned());
      allow delete: if signedIn() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /conversations/{conversationId} {
      allow read, update, delete: if signedIn() && request.auth.uid in resource.data.userIds;
      allow create: if signedIn() && request.auth.uid in request.resource.data.userIds;

      match /messages/{messageId} {
        allow read, write: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.userIds;
      }
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && request.auth.uid == resource.data.userId;
      allow create: if signedIn() && (request.auth.uid == request.resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
