<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chỉnh sửa bài đăng"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioRent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cho thuê" />

            <RadioButton
                android:id="@+id/radioRoommate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Ở ghép" />
        </RadioGroup>

        <Spinner
            android:id="@+id/spinnerRoomType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Tiêu đề"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:hint="Mô tả"
            android:minLines="4"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Giá"
            android:inputType="numberDecimal"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Diện tích"
            android:inputType="numberDecimal"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Địa chỉ"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtDistrict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Quận/Huyện"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Tiện ích"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbWifi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wi-Fi" />

        <CheckBox
            android:id="@+id/cbParking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chỗ để xe" />

        <CheckBox
            android:id="@+id/cbPrivateWc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WC riêng" />

        <CheckBox
            android:id="@+id/cbAirConditioner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Máy lạnh" />

        <Button
            android:id="@+id/btnUpdatePost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Cập nhật bài đăng" />

    </LinearLayout>
</ScrollView>
