<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText
            android:id="@+id/edtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tiêu đề"
            android:textColor="@android:color/white"
            android:textColorHint="#AAAAAA" />

        <EditText
            android:id="@+id/edtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:hint="Mô tả"
            android:minLines="3"
            android:textColor="@android:color/white"
            android:textColorHint="#AAAAAA" />

        <EditText
            android:id="@+id/edtPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Giá"
            android:inputType="numberDecimal"
            android:textColor="@android:color/white"
            android:textColorHint="#AAAAAA" />

        <EditText
            android:id="@+id/edtArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Diện tích"
            android:inputType="numberDecimal"
            android:textColor="@android:color/white"
            android:textColorHint="#AAAAAA" />

        <EditText
            android:id="@+id/edtAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Địa chỉ"
            android:textColor="@android:color/white"
            android:textColorHint="#AAAAAA" />

        <EditText
            android:id="@+id/edtDistrict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Quận/Huyện"
            android:textColor="@android:color/white"
            android:textColorHint="#AAAAAA" />

        <RadioGroup
            android:id="@+id/radioGroupType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioRent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cho thuê"
                android:textColor="@android:color/white" />

            <RadioButton
                android:id="@+id/radioRoommate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="Ở ghép"
                android:textColor="@android:color/white" />
        </RadioGroup>

        <Button
            android:id="@+id/btnPickImages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Chọn ảnh từ thư viện" />

        <Button
            android:id="@+id/btnCaptureImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Chụp ảnh" />

        <Button
            android:id="@+id/btnCreatePanorama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Chọn ảnh panorama (360)" />

        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            android:background="#222222"
            android:contentDescription="preview"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/txtImageCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Đã chọn: 0 ảnh"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/txtPanoramaStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chưa có ảnh panorama"
            android:textColor="#BBBBBB" />

        <Button
            android:id="@+id/btnCreatePost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Đăng bài" />

    </LinearLayout>
</ScrollView>