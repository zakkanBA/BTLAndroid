<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đăng tin mới"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioGroupType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/radioRent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cho thuê nhà/phòng trọ" />

            <RadioButton
                android:id="@+id/radioRoommate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Tìm người ở ghép" />
        </RadioGroup>

        <Spinner
            android:id="@+id/spinnerRoomType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Tiêu đề (tối đa 100 ký tự)"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Giá thuê theo tháng"
            android:inputType="numberDecimal"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Diện tích (m²)"
            android:inputType="numberDecimal"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Địa chỉ"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <EditText
            android:id="@+id/edtDistrict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Quận/Huyện"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <Button
            android:id="@+id/btnUseCurrentLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Dùng vị trí hiện tại" />

        <EditText
            android:id="@+id/edtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top"
            android:hint="Mô tả chi tiết"
            android:minLines="4"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Tiện ích"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbWifi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wi-Fi" />

        <CheckBox
            android:id="@+id/cbParking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chỗ để xe" />

        <CheckBox
            android:id="@+id/cbPrivateWc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WC riêng" />

        <CheckBox
            android:id="@+id/cbAirConditioner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Máy lạnh" />

        <Button
            android:id="@+id/btnPickImages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Chọn ảnh từ thư viện" />

        <Button
            android:id="@+id/btnCaptureImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chụp ảnh mới" />

        <Button
            android:id="@+id/btnCreatePanorama"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chọn ảnh 360 (Panorama)" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerImages"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtImageCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Ảnh thường: 0/6"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/txtPanoramaStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Chưa có ảnh 360"
            android:textColor="?attr/colorOnSurface" />

        <Button
            android:id="@+id/btnPreviewPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Xem trước" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Xem trước bài đăng"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtPreviewSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="?attr/colorOnSurface" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerPreviewImages"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:layout_marginTop="12dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <Button
            android:id="@+id/btnCreatePost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Đăng bài" />

    </LinearLayout>
</ScrollView>
